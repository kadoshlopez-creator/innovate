Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # ── Redirect everything to /public ────────────────────────────────────────
    # If the request is not for the public folder already
    RewriteCond %{REQUEST_URI} !^/public/
    
    # Rewrite the request to the public folder
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# ── Fallback Security ─────────────────────────────────────────────────────────
# Block direct access to core files in case mod_rewrite fails
<FilesMatch "^(\.env|composer\.(json|lock)|\.htaccess|CLAUDE\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to core application folders
RewriteRule ^(config|database|src|vendor|languages|scratch)/.*$ - [F,L]
