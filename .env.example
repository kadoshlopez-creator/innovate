APP_NAME="Innovate"
APP_URL=http://innovate.test
APP_ENV=local
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=innovate_cms
DB_USERNAME=root
DB_PASSWORD=

# Token requerido para acceder a setup.php (cámbialo por algo aleatorio)
SETUP_TOKEN=

# Poner en true solo si el servidor está detrás de un proxy/load balancer de confianza
TRUST_PROXY=false
